# Required by ./scripts/deploy.sh and ./scripts/setup-postgres.sh.
# Copy this file to .env and fill in real values; .env is gitignored.
#
# Workflow:
#   1. Fill in passwords below (generate fresh ones — see openssl hint).
#   2. `set -a; source .env; set +a` to export to current shell.
#   3. Run `./scripts/deploy.sh` (provisions the Postgres server).
#   4. Run `./scripts/setup-postgres.sh` (creates schema + roles + migration).
#   5. setup-postgres.sh prints `az keyvault secret set` commands — run those
#      to transfer the URLs into KeyVault. Tools read from KV, NOT from .env.
#   6. Once KeyVault is populated, you can scrub passwords from .env (the
#      values now live in KV; tools resolve via @Microsoft.KeyVault references).

# === Postgres SERVER ADMIN (Bicep deploy needs these) ====================
# Generate fresh: openssl rand -base64 32
PG_ADMIN_USERNAME=pgadmin
PG_ADMIN_PASSWORD=__GENERATE_AND_PUT_INTO_KEYVAULT__

# === Application roles created by setup-postgres.sh ======================
# obs_writer is what each instrumented tool (doc_search, hermes, ...) uses.
# Least-privilege: SELECT/INSERT/UPDATE on the observability schema, no DDL.
OBS_WRITER_USERNAME=obs_writer
OBS_WRITER_PASSWORD=__GENERATE_AND_PUT_INTO_KEYVAULT__

# obs_reader is for read-only consumers (PowerBI dashboards, ad-hoc psql
# sessions). SELECT only.
OBS_READER_USERNAME=obs_reader
OBS_READER_PASSWORD=__GENERATE_AND_PUT_INTO_KEYVAULT__

# === Postgres host (only needed for setup-postgres.sh AFTER deploy) ======
# Filled in from the POSTGRESFQDN deploy.sh output. Until deploy.sh has run
# the first time, leave commented — setup-postgres.sh will refuse to start.
# PG_HOST=alpenland-observability-pg.postgres.database.azure.com

# === BYO Postgres alternative ===========================================
# If you flip provisionPostgres=false in bicep/parameters/main.bicepparam,
# point PG_HOST at your existing Postgres server and use that server's admin
# credentials in PG_ADMIN_USERNAME/PASSWORD above. The setup-postgres.sh
# script then bootstraps the schema + roles on the existing server.
