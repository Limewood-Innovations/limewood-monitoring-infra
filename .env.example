# Required by ./scripts/deploy.sh and ./scripts/setup-postgres.sh.
# Copy this file to .env and fill in real values; .env is gitignored.
#
# Workflow:
#   1. Fill in the 3 passwords below (generate fresh ones — openssl hint).
#   2. `set -a; source .env; set +a` to export to current shell.
#   3. Run `./scripts/deploy.sh` (provisions Postgres + KeyVault + the rest).
#      → automatically writes PG_HOST + KV_NAME back into this .env file.
#   4. `set -a; source .env; set +a` again to pick up PG_HOST + KV_NAME.
#   5. Run `./scripts/setup-postgres.sh` (creates schema + roles + migration
#      + writes the 3 SQLAlchemy URLs directly into the KeyVault from step 3).
#   6. After verifying secrets in KV, scrub the password lines from .env —
#      tools resolve them at runtime via @Microsoft.KeyVault references.

# === Postgres SERVER ADMIN (Bicep deploy needs these) ====================
# Generate fresh: openssl rand -base64 32
PG_ADMIN_USERNAME=pgadmin
PG_ADMIN_PASSWORD=__GENERATE_AND_PUT_INTO_KEYVAULT__

# === Application roles created by setup-postgres.sh ======================
# obs_writer is what each instrumented tool (doc_search, hermes, ...) uses.
# Least-privilege: SELECT/INSERT/UPDATE on the observability schema, no DDL.
OBS_WRITER_USERNAME=obs_writer
OBS_WRITER_PASSWORD=__GENERATE_AND_PUT_INTO_KEYVAULT__

# obs_reader is for read-only consumers (PowerBI dashboards, ad-hoc psql
# sessions). SELECT only.
OBS_READER_USERNAME=obs_reader
OBS_READER_PASSWORD=__GENERATE_AND_PUT_INTO_KEYVAULT__

# === Auto-populated by deploy.sh (don't fill in manually) ================
# Both lines are written + replaced by deploy.sh on every successful run.
# PG_HOST=alpenland-observability-pg.postgres.database.azure.com
# KV_NAME=alpenland-obs-shared-kv

# === Override KV name BEFORE deploy.sh ===================================
# KV names are globally unique across Azure. If `alpenland-obs-shared-kv`
# is already taken (very unlikely but possible), uncomment + override here:
# KV_NAME=alpenland-obs-shared-kv-xyz

# === Postgres firewall — operator IP =====================================
# deploy.sh auto-detects your public IPv4 via ifconfig.me and adds it to
# the Postgres firewall as rule 'AllowDeployer' so setup-postgres.sh can
# connect from your laptop. Override with a fixed IP, or set 'skip' to
# disable the rule entirely (only if you run setup-postgres.sh from inside
# Azure already covered by AllowAllAzureIPs).
# DEPLOYER_IP=skip
# DEPLOYER_IP=203.0.113.42

# === BYO Postgres alternative ===========================================
# If you flip provisionPostgres=false in bicep/parameters/main.bicepparam,
# point PG_HOST at your existing Postgres server and use that server's admin
# credentials in PG_ADMIN_USERNAME/PASSWORD above. The setup-postgres.sh
# script then bootstraps the schema + roles on the existing server.
